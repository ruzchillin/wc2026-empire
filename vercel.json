{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.xml", "use": "@vercel/static" },
    { "src": "*.txt", "use": "@vercel/static" }
  ],
  "env": {
    "RAILWAY_API_URL": "https://wc2026-empire-production.up.railway.app"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://wc2026-empire-production.up.railway.app/api/$1",
      "headers": { "x-forwarded-host": "$host" }
    },
    { "src": "/go/bet365",      "dest": "https://www.bet365.com/?affiliate=YOUR_BET365_ID",   "status": 302 },
    { "src": "/go/betfair",     "dest": "https://promotions.betfair.com/betfair-welcome-offer?aff=YOUR_BETFAIR_ID", "status": 302 },
    { "src": "/go/draftkings",  "dest": "https://www.draftkings.com/?affiliate=YOUR_DK_ID",     "status": 302 },
    { "src": "/go/betmgm",      "dest": "https://sports.betmgm.com/?affiliate=YOUR_BETMGM_ID", "status": 302 },
    { "src": "/go/fanduel",     "dest": "https://www.fanduel.com/betting?affiliate=YOUR_FD_ID", "status": 302 },
    { "src": "/go/williamhill", "dest": "https://sports.williamhill.com/?affiliate=YOUR_WH_ID", "status": 302 },
    { "src": "/go/paddypower",  "dest": "https://www.paddypower.com/?aff=YOUR_PP_ID",           "status": 302 },
    { "src": "/go/betway",      "dest": "https://www.betway.com/?affiliate=YOUR_BETWAY_ID",     "status": 302 },
    { "src": "/go/unibet",      "dest": "https://www.unibet.com/?affiliate=YOUR_UNIBET_ID",     "status": 302 },
    { "src": "/go/888sport",    "dest": "https://www.888sport.com/?affiliate=YOUR_888_ID",      "status": 302 },
    {
      "src": "/go/(.*)",
      "dest": "https://wc2026-empire-production.up.railway.app/go/$1"
    },
    { "src": "/", "dest": "/index.html" },
    { "src": "/command-center", "dest": "/empire-command.html" },
    { "src": "/empire-command", "dest": "/empire-command.html" },
    { "src": "/status", "dest": "/status.html" },
    { "src": "/win-share", "dest": "/win-share.html" },
    { "src": "/england", "dest": "/england-wc2026.html" },
    { "src": "/italy", "dest": "/italy-wc2026.html" },
    { "src": "/portugal", "dest": "/portugal-wc2026.html" },
    { "src": "/mexico", "dest": "/mexico-wc2026.html" },
    { "src": "/poland", "dest": "/poland-wc2026.html" },
    { "src": "/belgium", "dest": "/belgium-wc2026.html" },
    { "src": "/kane", "dest": "/kane-wc2026.html" },
    { "src": "/saka", "dest": "/saka-wc2026.html" },
    { "src": "/son", "dest": "/son-wc2026.html" },
    { "src": "/salah", "dest": "/salah-wc2026.html" },
    { "src": "/pedri", "dest": "/pedri-wc2026.html" },
    { "src": "/musiala", "dest": "/musiala-wc2026.html" },
    { "src": "/wirtz", "dest": "/wirtz-wc2026.html" },
    { "src": "/osimhen", "dest": "/osimhen-wc2026.html" },
    { "src": "/hakimi", "dest": "/hakimi-wc2026.html" },
    { "src": "/lewandowski", "dest": "/lewandowski-wc2026.html" },
    { "src": "/messi-vs-ronaldo", "dest": "/messi-vs-ronaldo.html" },
    { "src": "/mbappe-vs-haaland", "dest": "/mbappe-vs-haaland.html" },
    { "src": "/live-scores", "dest": "/live-scores.html" },
    { "src": "/ai-predictions", "dest": "/ai-predictions.html" },
    { "src": "/odds-comparison", "dest": "/odds-comparison.html" },
    { "src": "/injury-tracker", "dest": "/injury-tracker.html" },
    { "src": "/squad-tracker", "dest": "/squad-tracker.html" },
    { "src": "/head-to-head", "dest": "/head-to-head.html" },
    { "src": "/var-tracker", "dest": "/var-tracker.html" },
    { "src": "/elimination-memorial", "dest": "/elimination-memorial.html" },
    { "src": "/elimination/(?<team>[^/]+)", "dest": "/elimination-memorial.html?team=$team" },
    { "src": "/pub-quiz", "dest": "/pub-quiz-generator.html" },
    { "src": "/pub-quiz-generator", "dest": "/pub-quiz-generator.html" },
    { "src": "/fan-zones", "dest": "/wc2026-fan-zones.html" },
    { "src": "/fan-zones/(?<city>[^/]+)", "dest": "/wc2026-fan-zones.html?city=$city" },
    { "src": "/tax-calculator", "dest": "/wc2026-tax-calculator.html" },
    { "src": "/betting-tax", "dest": "/wc2026-tax-calculator.html" },
    { "src": "/indonesia", "dest": "/indonesia-wc2026.html" },
    { "src": "/india", "dest": "/india-wc2026-hindi.html" },
    { "src": "/nigeria", "dest": "/nigeria-supereagles.html" },
    { "src": "/super-eagles", "dest": "/nigeria-supereagles.html" },
    { "src": "/win-share", "dest": "/win-share.html" },
    { "src": "/beat-the-ai", "dest": "/beat-the-ai.html" },
    { "src": "/emotional-hedge", "dest": "/emotional-hedge.html" },
    { "src": "/horse-racing", "dest": "/horse-racing.html" },
    { "src": "/nfl-picks", "dest": "/nfl-picks.html" },
    { "src": "/greyhounds", "dest": "/greyhounds.html" },
    { "src": "/cricket", "dest": "/cricket-india.html" },
    { "src": "/womens-sport", "dest": "/womens-sports-hub.html" },
    { "src": "/micro-betting", "dest": "/micro-betting.html" },
    { "src": "/same-game-parlay", "dest": "/same-game-parlay.html" },
    { "src": "/(?<slug>[^/\\.]+)", "dest": "/$slug.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/onesignal-push.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
