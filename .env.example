# ── PHASE 3: GLOBAL PLATFORMS ────────────────────────────────────────────────

# ── KAKAO ENGINE (Port 3046) — KakaoTalk Channel, Korea, 47M users ───────────
# 1. Go to https://developers.kakao.com → My Applications → Create App
# 2. Enable "KakaoTalk Channel Message" product
# 3. Get Access Token from REST API key flow (POST /oauth/token)
# 4. Create a KakaoTalk Channel at https://center-pf.kakao.com
# 5. Link the channel to your app and get the Channel ID (public link handle)
KAKAO_ACCESS_TOKEN=your_kakao_access_token
KAKAO_CHANNEL_ID=your_kakao_channel_id
KAKAO_ENGINE_URL=https://kakao-engine-production-xxxx.up.railway.app

# ── ZALO ENGINE (Port 3047) — Zalo OA, Vietnam, 75M users ───────────────────
# 1. Register at https://oa.zalo.me/home → Create Official Account
# 2. Go to https://developers.zalo.me → Create App → get App ID + Secret
# 3. Generate Access Token via OAuth at https://oauth.zaloapp.me/v4/permission
# 4. Get OA ID from your Official Account profile page
ZALO_ACCESS_TOKEN=your_zalo_oa_access_token
ZALO_OA_ID=your_zalo_oa_id
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret
ZALO_ENGINE_URL=https://zalo-engine-production-xxxx.up.railway.app

# ── VK ENGINE (Port 3048) — VKontakte, Russia/CIS, 100M MAU ─────────────────
# 1. Go to https://vk.com/apps?act=manage → Create App (type: Standalone)
# 2. Get Access Token with wall,groups permissions:
#    https://oauth.vk.com/authorize?client_id=YOUR_APP_ID&scope=wall,groups&response_type=token
# 3. Create or use existing community at https://vk.com/groups
# 4. Get Group ID from the community URL (e.g. vk.com/club123456 → ID is 123456)
VK_ACCESS_TOKEN=your_vk_community_access_token
VK_GROUP_ID=your_vk_group_id
VK_API_VERSION=5.199
VK_ENGINE_URL=https://vk-engine-production-xxxx.up.railway.app

# ── WEIBO + WECHAT ENGINE (Port 3049) — China, 600M+ users ──────────────────
# WEIBO:
# 1. Apply at https://open.weibo.com/apps → Create Application
# 2. Get Access Token via OAuth2: https://api.weibo.com/oauth2/authorize
# 3. Get your Weibo UID from https://weibo.com/ajax/profile/info
# WECHAT:
# 1. Register Official Account at https://mp.weixin.qq.com
# 2. Get AppID + AppSecret from Settings → Development → Basic Configuration
# 3. Token is auto-refreshed by weibo-engine.js — just supply AppID + Secret
WEIBO_ACCESS_TOKEN=your_weibo_access_token
WEIBO_UID=your_weibo_user_id
WECHAT_APP_ID=your_wechat_official_account_appid
WECHAT_APP_SECRET=your_wechat_official_account_appsecret
WEIBO_ENGINE_URL=https://weibo-engine-production-xxxx.up.railway.app

# ── NAIRALAND ENGINE (Port 3050) — Nigeria forum, 3M users ──────────────────
# 1. Register at https://www.nairaland.com/register
# 2. Log in, then grab your session cookie from browser DevTools
#    (Application → Cookies → nairaland.com → look for session cookie)
# NOTE: If no session cookie, engine falls back to sending draft via Telegram
# NAIRALAND_BOARD: 4=Sports (default), 1=Politics, 2=Romance, 3=Jobs
NAIRALAND_SESSION=your_nairaland_session_cookie_value
NAIRALAND_USERNAME=your_nairaland_username
NAIRALAND_BOARD=4
NAIRALAND_ENGINE_URL=https://nairaland-engine-production-xxxx.up.railway.app

# ── EMPIRE AGENT (Port 3051) — Master AI brain + conversational interface ────
# No external API keys needed — uses Groq (already configured above)
# EMPIRE_CHAT_KEY: secret key for empire-chat.html web interface (make one up)
# Example: openssl rand -hex 32
EMPIRE_CHAT_KEY=your_empire_chat_secret_key_32chars
EMPIRE_AGENT_URL=https://empire-agent-production-xxxx.up.railway.app

# ── GROWTH AGENT (Port 3052) — Virality detection + auto-amplification ───────
# No external API keys needed — uses Telegram + Groq (already configured above)
# Uses OWNER_CHAT_ID from personal-agent section above (same Telegram user ID)
GROWTH_AGENT_URL=https://growth-agent-production-xxxx.up.railway.app

# ── TRAFFIC AMPLIFIER (Port 3053) — SEO + content distribution engine ────────
# Pings Google/Bing/Yandex on new content, XML-RPC blog pings, social bookmarking,
# RSS aggregator submission, press release generation, backlink outreach.
# All legitimate SEO/content amplification — drives real human traffic.
#
# IndexNow (Bing/Yandex multi-ping protocol):
# 1. Generate a random key: openssl rand -hex 16
# 2. Create a file at your site root: /[key].txt containing just that key
# 3. Add key below
INDEXNOW_KEY=your_indexnow_key_from_step1
#
# Pocket (save-to-read-later → discover algorithm exposure):
# 1. Create app at https://getpocket.com/developer/apps/new
# 2. Get consumer key, then auth flow for access token
POCKET_CONSUMER_KEY=your_pocket_consumer_key
POCKET_ACCESS_TOKEN=your_pocket_access_token
#
# Mix.com (StumbleUpon successor — content discovery):
# Register at https://mix.com/developers
MIX_API_TOKEN=your_mix_api_token
#
# Feedly (15M users — RSS discovery + syndication):
# OAuth at https://developer.feedly.com
FEEDLY_ACCESS_TOKEN=your_feedly_access_token
#
# Feedspot (sports blog directory submission):
# API key from https://www.feedspot.com/publishers
FEEDSPOT_API_TOKEN=your_feedspot_api_token
#
TRAFFIC_AMPLIFIER_URL=https://traffic-amplifier-production-xxxx.up.railway.app

