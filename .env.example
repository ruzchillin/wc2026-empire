# ============================================================
# WC 2026 EMPIRE — COMPLETE ENVIRONMENT VARIABLES
# Copy this to .env and fill in every value before deploying
# ============================================================

# --- AI (REQUIRED) ---
GROQ_API_KEY=your_groq_api_key_here          # groq.com — free 500K tokens/day

# --- SPORTS DATA (REQUIRED) ---
RAPIDAPI_KEY=your_rapidapi_key_here          # rapidapi.com — football API
THE_ODDS_API_KEY=your_odds_api_key_here      # the-odds-api.com — betting odds

# --- TELEGRAM (REQUIRED) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token   # @BotFather
TELEGRAM_CHANNEL_ID=@your_channel_id         # main EN channel
TELEGRAM_ES_CHANNEL_ID=@your_es_channel      # Spanish channel
TELEGRAM_PT_CHANNEL_ID=@your_pt_channel      # Portuguese channel
TELEGRAM_AR_CHANNEL_ID=@your_ar_channel      # Arabic channel
TELEGRAM_FR_CHANNEL_ID=@your_fr_channel      # French channel
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id    # your personal chat ID for alerts

# --- WHATSAPP BUSINESS API (REQUIRED) ---
WA_PHONE_NUMBER_ID=your_phone_number_id      # Meta Cloud API
WA_ACCESS_TOKEN=your_permanent_access_token  # Meta developer dashboard
WA_VERIFY_TOKEN=wc2026_webhook_secret        # any string you choose
WA_PORT=3001

# --- TWITTER / X ---
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# --- FACEBOOK / META ---
FACEBOOK_PAGE_TOKEN=your_page_access_token
FACEBOOK_PAGE_ID=your_page_id

# --- INSTAGRAM (via Facebook Graph API) ---
INSTAGRAM_USER_ID=your_instagram_user_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_token

# --- LINKEDIN ---
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_ORG_ID=your_organization_id

# --- REDDIT ---
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# --- DISCORD (v2 — discord-bot.js, Port 3022) ---
DISCORD_BOT_TOKEN=your_discord_bot_token         # discordapp.com/developers → Bot → Token
DISCORD_CHANNEL_ID=your_server_channel_id        # Right-click channel → Copy ID

# Discord v2 additions (discord-bot.js rewrite — Task #120)
DISCORD_CLIENT_ID=your_discord_application_id    # discordapp.com/developers → Application ID
DISCORD_GUILD_IDS=                                # Comma-separated server IDs for fast guild command registration
                                                  # Leave empty for global commands (takes ~1hr to propagate)
                                                  # e.g. 123456789,987654321
DISCORD_VIP_ROLE_NAME=VIP                         # Role name for /vip command restricted tips (case-sensitive)
                                                  # Create this role in your Discord server first

# --- EMAIL / BEEHIIV ---
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=your_publication_id

# --- MEDIUM ---
MEDIUM_ACCESS_TOKEN=your_medium_token        # OAuth token (for user API)
MEDIUM_USER_ID=your_medium_user_id
# medium-engine.js uses Integration Token (different from OAuth):
MEDIUM_INTEGRATION_TOKEN=your_medium_integration_token  # medium.com/me/settings -> Integration Tokens
MEDIUM_PUBLICATION_ID=your_publication_id    # GET https://api.medium.com/v1/me/publications

# --- SUBSTACK ---
SUBSTACK_COOKIE=your_substack_session_cookie

# --- THREADS (via Instagram API) ---
THREADS_ACCESS_TOKEN=your_threads_token
THREADS_USER_ID=your_threads_user_id

# --- AFRICA'S TALKING (SMS) ---
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username

# --- ELEVENLABS (AI VOICE / PODCAST) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID_EN=voice_id_english
ELEVENLABS_VOICE_ID_ES=voice_id_spanish
ELEVENLABS_VOICE_ID_PT=voice_id_portuguese
ELEVENLABS_VOICE_ID_AR=voice_id_arabic

# --- WEB PUSH NOTIFICATIONS ---
VAPID_PUBLIC_KEY=your_vapid_public_key       # generate with web-push
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:you@youremail.com

# --- VERCEL (auto-redeploy trigger) ---
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/your_hook_id

# --- SERVER ---
PORT=3000
NODE_ENV=production
BASE_URL=https://your-railway-domain.railway.app
SITE_URL=https://your-vercel-domain.vercel.app
VERCEL_URL=https://your-vercel-domain.vercel.app

# --- WHOP (PREMIUM GATING) ---
WHOP_API_KEY=your_whop_api_key

# --- JWT (AUTHENTICATION) ---
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# --- AFFILIATE TRACKING ---
BET365_AFFILIATE_ID=your_bet365_id           # partners.bet365.com
BETWAY_AFFILIATE_ID=your_betway_id           # betwaypartners.com
DRAFTKINGS_AFFILIATE_ID=your_dk_id           # draftkingsaffiliates.com
DREAM11_AFFILIATE_ID=your_dream11_id         # dream11.com/affiliates
SORARE_AFFILIATE_ID=your_sorare_id           # sorare.com/affiliates
NORDVPN_AFFILIATE_ID=your_nordvpn_id         # nordvpn.com/affiliates
BOOKING_AFFILIATE_ID=your_booking_id         # booking.com/affiliate-program
AMAZON_ASSOCIATE_ID=your_amazon_id           # affiliate-program.amazon.com
STAKE_AFFILIATE_ID=your_stake_id             # stake.com affiliates

# --- OPTIONAL: SUBSCRIPTION BOX ---
CRATEJOY_API_KEY=your_cratejoy_key

# --- OPTIONAL: PAYMENTS (STRIPE) ---
STRIPE_SECRET_KEY=sk_REPLACE_WITH_LIVE_KEY
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PREMIUM_PRICE_ID=price_monthly_premium
STRIPE_TOURNAMENT_PRICE_ID=price_tournament_pass

# --- BLUESKY (bluesky-engine.js) ---
BLUESKY_HANDLE=yourname.bsky.social         # Create at bsky.app, then Settings -> App Passwords
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx    # NOT your real password — generate app password
BLUESKY_PORT=3006

# --- MASTODON (mastodon-engine.js) ---
MASTODON_INSTANCE=https://sports.social     # Or mastodon.social — create account there first
MASTODON_ACCESS_TOKEN=your_mastodon_token   # Settings -> Development -> New Application
MASTODON_PORT=3007

# --- PODCAST (podcast-engine.js) ---
ELEVENLABS_API_KEY=your_elevenlabs_key      # elevenlabs.io — free 10K chars/month
GOOGLE_TTS_KEY=your_google_tts_key          # console.cloud.google.com — 1M chars free/month
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel voice (neutral, clear) — or choose another
PODCAST_BASE_URL=https://podcast.yoursite.com
PODCAST_TITLE=WC 2026 Daily — AI Match Analysis
PODCAST_AUTHOR=WC 2026 Live
PODCAST_PORT=3008

# --- NEWS SYNDICATION (news-syndication-engine.js) ---
# Apple News: apply at news.apple.com/publisher (takes 1-2 weeks for approval)
APPLE_NEWS_CHANNEL_ID=your_channel_id       # from Apple News Publisher dashboard
APPLE_NEWS_API_KEY=your_api_key
APPLE_NEWS_API_SECRET=your_api_secret
NEWS_PORT=3009

# --- SNAPCHAT (snapchat-engine.js) ---
# Snapchat Public Profile required — apply at business.snapchat.com
SNAPCHAT_CLIENT_ID=your_client_id           # Snapchat Business Manager -> App
SNAPCHAT_CLIENT_SECRET=your_client_secret
SNAPCHAT_ACCESS_TOKEN=your_access_token     # OAuth2 — refresh monthly
SNAPCHAT_PROFILE_ID=your_profile_id         # Public Profile ID
SNAPCHAT_PORT=3010

# --- NAVER / KOREA (naver-engine.js) ---
NAVER_CLIENT_ID=your_naver_client_id        # developers.naver.com -> Application
NAVER_CLIENT_SECRET=your_naver_secret
NAVER_ACCESS_TOKEN=your_naver_oauth_token   # OAuth2 via Naver Login API
NAVER_BLOG_ID=your_blog_id                  # Your Naver blog ID
NAVER_PORT=3011

# --- SHARECHAT / INDIA (sharechat-engine.js) ---
# No API key needed — content generated by Groq and saved as files
SHARECHAT_PORT=3012

# --- TWITCH BOT (twitch-bot.js) ---
# Create a separate Twitch account for the bot (e.g. WC2026LiveBot)
TWITCH_BOT_USERNAME=WC2026LiveBot            # Your bot's Twitch username
TWITCH_BOT_TOKEN=oauth:xxxxxxxxxx            # Get at twitchapps.com/tmi/
TWITCH_CLIENT_ID=your_client_id             # dev.twitch.tv -> Register Application
TWITCH_CLIENT_SECRET=your_client_secret
TWITCH_PORT=3013

# --- WEB STORIES (web-stories-generator.js) ---
STORIES_PORT=3014

# --- LINKEDIN (linkedin-post-engine.js) ---
# IMPORTANT: LinkedIn access tokens expire. Set calendar reminder to refresh every 60 days.
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXX  # GET https://api.linkedin.com/v2/me -> id field
LINKEDIN_ORG_URN=urn:li:organization:XXXXXX  # Optional — for company page posting
LINKEDIN_PORT=3015

# ─── IMAGE ENGINE (Port 3016) ──────────────────────────────────────────────────
# No extra credentials needed — uses @napi-rs/canvas (pure Node.js)
# Install: npm install @napi-rs/canvas
IMAGE_ENGINE_URL=https://image-engine.up.railway.app  # your Railway URL after deploy
IMAGE_PORT=3016

# ─── VISUAL POST ENGINE (Port 3017) ───────────────────────────────────────────
# Instagram Graph API:
# 1. Create Facebook App at developers.facebook.com
# 2. Add Instagram Graph API product
# 3. Connect your Instagram Business/Creator account
# 4. Generate long-lived token: GET /oauth/access_token?grant_type=fb_exchange_token
# 5. GET /me/accounts → find your Instagram Business Account
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx    # long-lived page access token
INSTAGRAM_USER_ID=17841400000000   # numeric IG Business Account ID

# TikTok Content Posting API:
# 1. Register at developers.tiktok.com
# 2. Create app → request Content Posting API scope
# 3. OAuth2 flow → get access_token with scope: video.upload,video.list
TIKTOK_ACCESS_TOKEN=act.xxxxxxxxxx

# This service needs to be publicly accessible so Instagram/TikTok can pull image URLs
VISUAL_ENGINE_PUBLIC_URL=https://visual-post-engine.up.railway.app
VISUAL_PORT=3017

# ─── MONITOR BOT (Port 3020) ──────────────────────────────────────────────────
# Railway API:
# Get token from: railway.app → Account Settings → Tokens
RAILWAY_API_TOKEN=xxxxxxxxxxxxxxxx
RAILWAY_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # from railway.app project URL

# Telegram (already set above if you set TELEGRAM_BOT_TOKEN)
# TELEGRAM_OWNER_ID = YOUR personal chat ID (not channel, your own DMs)
# Get it: message @userinfobot on Telegram → it replies with your ID
TELEGRAM_OWNER_ID=123456789    # your personal numeric Telegram user ID

MONITOR_PORT=3020

# ─── COMMENTARY LIVE ENGINE (Port 3018) ───────────────────────────────────────
# Groq, Telegram, Bluesky, Mastodon already configured above
# Just needs these engine URLs:
COMMENTARY_ENGINE_URL=https://commentary-live-engine.up.railway.app
COMMENTARY_PORT=3018

# ─── NEWS MONITOR (Port 3019) ─────────────────────────────────────────────────
# No extra credentials — polls public RSS feeds
# Distributes via Telegram, Bluesky, Mastodon, News Syndication engine
NEWS_MONITOR_URL=https://news-monitor.up.railway.app
NEWS_MONITOR_PORT=3019

# ─── SCHEMA INJECTOR ──────────────────────────────────────────────────────────
# Google AdSense: apply at adsense.google.com
# Once approved, find your publisher ID in AdSense dashboard:
#   My ads → Ad units → "Get code" → look for ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Run after generating HTML: npm run inject

# ─── FACEBOOK ENGINE + THREADS (Port 3021) ────────────────────────────────────
# Facebook Page:
#   1. Create a Facebook Page (not profile) for WC 2026
#   2. Go to developers.facebook.com → My Apps → Create App → Business
#   3. Add Facebook Login + Pages API products
#   4. Graph API Explorer → select your Page → Generate Page Access Token
#   5. Page ID: Go to your page → About → scroll to "Page ID" at bottom
FACEBOOK_PAGE_ID=123456789012345         # numeric Page ID
FACEBOOK_PAGE_TOKEN=EAA...               # long-lived Page token (doesn't expire)
FACEBOOK_ENGINE_URL=https://facebook-engine.up.railway.app
FACEBOOK_PORT=3021

# Threads uses INSTAGRAM_ACCESS_TOKEN + INSTAGRAM_USER_ID (already configured above)

# ─── DISCORD BOT (Port 3022) ──────────────────────────────────────────────────
# 1. discord.com/developers/applications → New Application → Bot
# 2. Bot → Reset Token → copy DISCORD_BOT_TOKEN
# 3. Enable: Message Content Intent, Server Members Intent
# 4. OAuth2 URL: discord.com/oauth2/authorize?client_id=YOUR_ID&scope=bot+applications.commands&permissions=2147560448
# 5. Share invite URL with server owners (r/worldcup Discord, football fan servers)
DISCORD_BOT_TOKEN=MTxxxxxxxxxxxxxxxx.Gxxxxx.xxxxxxxxxxxxxxxxxxxx
DISCORD_CHANNEL_IDS=1234567890,9876543210  # comma-sep channel IDs to post in (optional)
DISCORD_BOT_URL=https://discord-bot.up.railway.app
DISCORD_PORT=3022

# ─── REDDIT BOT (Port 3023) ───────────────────────────────────────────────────
# 1. reddit.com/prefs/apps/ → create another app → choose "script"
# 2. Name: WC2026Bot, description: AI WC 2026 updates, redirect: http://localhost:8080
# 3. Client ID = the string under your app name (NOT the secret)
# 4. Client Secret = the "secret" field
# NOTE: New accounts have posting restrictions. Age the account by commenting for ~1 week first.
REDDIT_CLIENT_ID=xxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_USERNAME=YourBotUsername          # the Reddit account username (without u/)
REDDIT_PASSWORD=YourBotPassword          # the Reddit account password
REDDIT_USER_AGENT=WC2026Bot/1.0 by u/YourBotUsername
REDDIT_BOT_URL=https://reddit-bot.up.railway.app
REDDIT_PORT=3023

# ─── STRIPE WEBHOOK (Port 3024) ───────────────────────────────────────────────
# 1. stripe.com → Dashboard → Developers → API keys → copy secret key
# 2. Dashboard → Developers → Webhooks → Add endpoint
#    URL: https://your-stripe-webhook.up.railway.app/webhook
#    Events: checkout.session.completed, payment_intent.succeeded,
#            customer.subscription.created, customer.subscription.deleted
# 3. Click the endpoint → Signing Secret → copy and set as STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=sk_REPLACE_WITH_LIVE_KEY   # or sk_REPLACE_WITH_TEST_KEY_ for testing
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_PREMIUM_CHAT_ID=-100xxxxxxxxxx  # premium members Telegram channel ID
STRIPE_PORT=3024

# ─── YOUTUBE UPLOADER (Port 3025) ─────────────────────────────────────────────
# Full OAuth2 flow required (one-time, run locally):
# 1. console.cloud.google.com → New Project → Enable YouTube Data API v3
# 2. Credentials → OAuth 2.0 Client ID → Desktop application → Download JSON
# 3. Run: node youtube-uploader.js --auth
#    → Opens browser, sign in as your YouTube channel
#    → Paste code → refresh token saved to .youtube-token.json
# 4. Copy YOUTUBE_REFRESH_TOKEN from .youtube-token.json to here
YOUTUBE_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_UPLOADER_URL=https://youtube-uploader.up.railway.app
YOUTUBE_PORT=3025

# ─── TRANSLATION PROCESSOR (Port 3026) ───────────────────────────────────────
# Uses Groq (already configured above) — no additional credentials needed.
# Translates to: es, pt, ar, fr, de, hi, id, sw, tr, ko (10 languages)
# Routes to: Bluesky, Mastodon, Snapchat, ShareChat, Naver, Facebook, Reddit, SMS
TRANSLATION_ENGINE_URL=https://translation-processor.up.railway.app
TRANSLATION_PORT=3026

# ─── QUEUE PROCESSOR (Port 3027) ─────────────────────────────────────────────
# Email: choose ONE provider
# Option A — SendGrid (recommended):
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B — SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password    # Gmail: myaccount.google.com/apppasswords
EMAIL_FROM=WC 2026 Live <noreply@wc2026live.app>

# OneSignal push notifications:
# Get from: onesignal.com → Your App → Settings → Keys & IDs
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Africa's Talking SMS (for East African markets):
AT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AT_USERNAME=your_at_username
AT_SENDER_ID=WC2026

QUEUE_PROCESSOR_URL=https://queue-processor.up.railway.app
QUEUE_PORT=3027

# ─── DEDUP GUARD (Port 3033) ─────────────────────────────────────────────────
# No external credentials needed — pure in-memory dedup cache.
# Engines call POST /check before posting to prevent duplicate content.
DEDUP_GUARD_URL=https://dedup-guard.up.railway.app
DEDUP_PORT=3033

# ─── GROQ BUDGET GUARD (Port 3036) ───────────────────────────────────────────
# Central token pool manager. Prevents 25+ engines burning 500K tokens in minutes.
# Engines call POST /tokens/request before Groq, POST /tokens/report after.
# GROQ_DAILY_LIMIT: leave as 480000 (20K buffer from 500K free tier)
GROQ_BUDGET_URL=https://groq-budget-guard.up.railway.app
GROQ_BUDGET_PORT=3036
GROQ_DAILY_LIMIT=480000

# ─── SITEMAP GENERATOR (Port 3035) ───────────────────────────────────────────
# Scans public/ for all HTML pages, generates sitemap.xml, pings Google.
# Runs once on deploy + daily cron at 03:00 UTC.
# POST /generate to trigger manually.
# Optional: Google Search Console Indexing API for faster indexing (advanced):
# GOOGLE_INDEXING_API_KEY=your_service_account_json_base64
SITEMAP_URL=https://sitemap-generator.up.railway.app
SITEMAP_PORT=3037

# ─── COOKIE CONSENT + PRIVACY ────────────────────────────────────────────────
# No credentials needed — cookie-consent.js is a client-side script.
# Add to pages: <script src="/cookie-consent.js" defer></script>
# Required for Google AdSense approval. Privacy policy at /privacy-policy.html.
# Optional: Google Analytics ID (fires only after consent granted)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ─── PERSONAL AGENT (Port 3038) — Your private Telegram AI assistant ─────────
# This bot DMs only you — real-time briefings, revenue updates, /status commands.
# 1. Message @BotFather on Telegram → /newbot → give it a name → copy token
# 2. Message @userinfobot → copy your numeric ID as OWNER_CHAT_ID
PERSONAL_BOT_TOKEN=your_personal_bot_token      # DIFFERENT from TELEGRAM_BOT_TOKEN
OWNER_CHAT_ID=your_numeric_telegram_user_id     # ONLY this ID can send commands
PERSONAL_AGENT_URL=https://personal-agent-production-xxxx.up.railway.app

# ─── LINE ENGINE (Port 3039) — Japan / Thailand / Taiwan / Indonesia ──────────
# 82M daily active users in Japan alone. Worth the 5-min setup.
# 1. developers.line.biz → Providers → Create a provider
# 2. Create a Messaging API channel → copy Channel access token (long-lived)
# 3. LINE Notify: notify.line.me → Generate token → connect to a group/channel
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_NOTIFY_TOKEN=your_line_notify_token         # simpler — one token = one group
LINE_CHANNEL_SECRET=your_line_channel_secret     # for webhook signature verification
LINE_ENGINE_URL=https://line-engine-production-xxxx.up.railway.app
LINE_ENGINE_PORT=3039

# ─── VIBER ENGINE (Port 3040) — Philippines / Eastern Europe / Middle East ────
# 260M+ users. #1 app in Philippines (40M), Ukraine, Bulgaria, Croatia, Serbia.
# 1. partners.viber.com → Create Bot Account → get Auth Token
# 2. Set VIBER_WEBHOOK_URL to your Railway URL — the engine registers it on boot
VIBER_AUTH_TOKEN=your_viber_auth_token
VIBER_BOT_NAME=WC 2026 Picks
VIBER_WEBHOOK_URL=https://viber-engine-production-xxxx.up.railway.app
VIBER_ENGINE_URL=https://viber-engine-production-xxxx.up.railway.app
VIBER_ENGINE_PORT=3040

# ─── ODDS ENGINE (Port 3041) — Live odds comparison + affiliate revenue ────────
# Biggest single revenue machine: every click on an odds cell = potential £30-250 CPA.
# 1. the-odds-api.com → Sign up → Free: 500 requests/month (enough for WC 2026)
# Note: the-odds-api uses ODDS_API_KEY (not THE_ODDS_API_KEY in the sports data section)
ODDS_API_KEY=your_the_odds_api_key              # from the-odds-api.com
ODDS_ENGINE_URL=https://odds-engine-production-xxxx.up.railway.app
ODDS_ENGINE_PORT=3041

# ─── MEDIUM ENGINE (Port 3042) — Auto-publish articles to Medium ─────────────
# Sets canonical URL back to wc2026picks.com so Google credits your site, not Medium.
# Already configured above (MEDIUM_INTEGRATION_TOKEN + MEDIUM_PUBLICATION_ID)
MEDIUM_ENGINE_URL=https://medium-engine-production-xxxx.up.railway.app
MEDIUM_ENGINE_PORT=3042

# ─── KOO ENGINE (Port 3043) — India's Twitter alternative (50M users) ────────
# Posts in Hindi with Hindi football terms. Huge untapped audience.
# 1. kooapp.com → Create account → Apply for API access at developer.kooapp.com
KOO_API_TOKEN=your_koo_api_token
KOO_USER_ID=your_koo_user_id
KOO_ENGINE_URL=https://koo-engine-production-xxxx.up.railway.app
KOO_ENGINE_PORT=3043

# ─── MERCHANDISE ENGINE (Port 3044) — Print-on-demand via Printful ───────────
# AI-generates product slogans on eliminations/hat-tricks, announces to Telegram.
# 1. printful.com → Sign up free → Stores → Connect store → API → Generate key
# 2. Copy your numeric Store ID from the store URL
PRINTFUL_API_KEY=your_printful_api_key
PRINTFUL_STORE_ID=your_printful_store_id        # numeric, from store URL
MERCH_ENGINE_URL=https://merchandise-engine-production-xxxx.up.railway.app
MERCH_ENGINE_PORT=3044

# ─── FANTASY ENGINE (Port 3045) — AI fantasy football picks ──────────────────
# Premium product — sell picks via Stripe/Whop subscription.
# Uses Groq (already configured) + FOOTBALL_API_KEY (already configured)
FANTASY_ENGINE_URL=https://fantasy-engine-production-xxxx.up.railway.app
FANTASY_ENGINE_PORT=3045

# ─── PIPELINE SECRET ─────────────────────────────────────────────────────────
# Shared secret for inter-service auth (x-pipeline-secret header).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# All 43 Railway services must have the same value.
PIPELINE_SECRET=generate_a_random_64_char_hex_string_here

# ─── RAILWAY SERVICE URLs ─────────────────────────────────────────────────────
# After deploying each service on Railway, paste its public URL here.
# Format: https://<service-name>-production-xxxx.up.railway.app
# These URLs let services call each other (inter-service communication).
# Leave as localhost for local dev — Railway auto-resolves in production.

# Priority 1 — deploy first (everything else depends on these)
DEDUP_GUARD_URL=https://dedup-guard-production-xxxx.up.railway.app
GROQ_BUDGET_URL=https://groq-budget-guard-production-xxxx.up.railway.app

# Priority 2 — infrastructure
STRIPE_WEBHOOK_URL=https://stripe-webhook-production-xxxx.up.railway.app
AFFILIATE_TRACKER_URL=https://affiliate-tracker-production-xxxx.up.railway.app
QUEUE_PROCESSOR_URL=https://queue-processor-production-xxxx.up.railway.app

# Priority 3 — core
WORLD_ENGINE_URL=https://world-engine-production-xxxx.up.railway.app
MOMENT_ENGINE_URL=https://moment-engine-production-xxxx.up.railway.app
API_SERVER_URL=https://api-server-production-xxxx.up.railway.app
DATA_PIPELINE_URL=https://data-pipeline-production-xxxx.up.railway.app

# Priority 4 — social engines
TELEGRAM_ENGINE_URL=https://telegram-engine-production-xxxx.up.railway.app
EMAIL_DIGEST_URL=https://email-digest-engine-production-xxxx.up.railway.app
