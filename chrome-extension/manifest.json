{
  "manifest_version": 3,
  "name": "WC 2026 Live Scores + Free Bets",
  "short_name": "WC2026",
  "description": "Live World Cup 2026 scores in your toolbar. Free bets, predictions and match alerts.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "WC 2026 Live Scores"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://api-football-v1.p.rapidapi.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
