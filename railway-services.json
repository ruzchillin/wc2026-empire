      "healthcheckPath": "/health",
      "restartPolicy": "ON_FAILURE",
      "port": 3003,
      "envVar": "WORLD_ENGINE_URL",
      "priority": 3,
      "note": "Intelligence hub \u2014 news monitoring, sharp money tracking, content generation, event correlation."
    },
    {
