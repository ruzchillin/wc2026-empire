{
  "$schema": "https://railway.app/railway.schema.json",
  "version": "2",
  "project": "wc2026-empire",
  "services": [
    {
      "name": "dedup-guard",
      "startCommand": "node dedup-guard.js",
      "healthcheckPath": "/health",
      "restartPolicy": "ON_FAILURE",
      "port": 3033,
      "envVar": "DEDUP_GUARD_URL",
      "priority": 1,
      "note": "Deploy FIRST \u2014 other engines depend on it. SHA256 event dedup."
    },
    {
      "name": "groq-budget-guard",
      "startCommand": "node groq-budget-guard.js",
      "healthcheckPath": "/health",
      "restartPolicy": "ON_FAILURE",
      "port": 3036,
      "envVar": "GROQ_BUDGET_URL",
      "priority": 1,
      "note": "Deploy FIRST \u2014 prevents Groq token burnout. 480K/day pool across all engines."
    },
    {
      "name": "queue-processor",
      "startCommand": "node queue-processor.js",
      "healthcheckPath": "/health",
      "restartPolicy": "ON_FAILURE",
      "port": 3027,
      "envVar": "QUEUE_PROCESSOR_URL",
      "priority": 2,
      "note": "Drains email/push/SMS queues every 30s. Dead-letter after 3 retries."
    },
    {
      "name": "stripe-webhook",
      "startCommand": "node stripe-webhook.js",
      "healthcheckPath": "/health",
      "restartPolicy": "ON_FAILURE",
      "port": 3024,
      "envVar": "STRIPE_WEBHOOK_URL",
